<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <_DefaultTargetPlatformVersion>10.0</_DefaultTargetPlatformVersion>
  </PropertyGroup>

  <PropertyGroup>
    <TargetPlatformSupported>true</TargetPlatformSupported>
    <TargetPlatformVersion Condition=" '$(TargetPlatformVersion)' == '' ">$(_DefaultTargetPlatformVersion)</TargetPlatformVersion>
    <_TargetFramework Condition="$(TargetFramework.EndsWith('tizen'))">$(TargetFramework)$(_DefaultTargetPlatformVersion)</_TargetFramework>
    <_TargetFramework Condition="!$(TargetFramework.EndsWith('tizen'))">$(TargetFramework)</_TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="tizen" />
  </ItemGroup>

  <ItemGroup>
    <SupportedAPILevel Include="v4.0" MappedAPIVersion="4.0"/>
    <SupportedAPILevel Include="v5.0" MappedAPIVersion="5.0"/>
    <SupportedAPILevel Include="v6.0" MappedAPIVersion="5.0"/>
    <SupportedAPILevel Include="v7.0" MappedAPIVersion="5.5"/>
    <SupportedAPILevel Include="v8.0" MappedAPIVersion="6.0"/>
    <SupportedAPILevel Include="v9.0" MappedAPIVersion="6.5"/>
    <SupportedAPILevel Include="v10.0" MappedAPIVersion="7.0"/>
    <SupportedAPILevel Include="v11.0" MappedAPIVersion="8.0"/>
    <SupportedAPILevel Include="v12.0" MappedAPIVersion="9.0"/>
    <SupportedAPILevel Include="v13.0" MappedAPIVersion="10.0"/>
    <SupportedAPILevel Include="v14.0" MappedAPIVersion="10.1"/>
    <SupportedAPILevel Include="v15.0" MappedAPIVersion="11.0"/>
  </ItemGroup>

  <ItemGroup>
    <!-- 7.0 was a development-only platform during initial bring-up; removed. -->
    <TizenSdkSupportedTargetPlatformVersion Include="8.0" />
    <TizenSdkSupportedTargetPlatformVersion Include="9.0" />
    <TizenSdkSupportedTargetPlatformVersion Include="10.0" />
    <TizenSdkSupportedTargetPlatformVersion Include="10.1" />
    <TizenSdkSupportedTargetPlatformVersion Include="11.0" />
  </ItemGroup>

  <ItemGroup>
    <SdkSupportedTargetPlatformVersion Include="@(TizenSdkSupportedTargetPlatformVersion)" />
  </ItemGroup>

  <ItemGroup>
    <KnownFrameworkReference
      Condition="'$(TargetPlatformVersion)' == '8.0'"
      Include="Samsung.Tizen"
      TargetFramework="$(_TargetFramework)"
      TargetingPackName="Samsung.Tizen.Ref.API11"
      TargetingPackVersion="@TizenFXAPI11Version@"
      Profile="Tizen"
    />
    <KnownFrameworkReference
      Condition="'$(TargetPlatformVersion)' == '9.0'"
      Include="Samsung.Tizen"
      TargetFramework="$(_TargetFramework)"
      TargetingPackName="Samsung.Tizen.Ref.API12"
      TargetingPackVersion="@TizenFXAPI12Version@"
      Profile="Tizen"
    />
    <KnownFrameworkReference
      Condition="'$(TargetPlatformVersion)' == '10.0'"
      Include="Samsung.Tizen"
      TargetFramework="$(_TargetFramework)"
      TargetingPackName="Samsung.Tizen.Ref.API13"
      TargetingPackVersion="@TizenFXAPI13Version@"
      Profile="Tizen"
    />
    <KnownFrameworkReference
      Condition="'$(TargetPlatformVersion)' == '10.1'"
      Include="Samsung.Tizen"
      TargetFramework="$(_TargetFramework)"
      TargetingPackName="Samsung.Tizen.Ref.API14"
      TargetingPackVersion="@TizenFXAPI14Version@"
      Profile="Tizen"
    />
    <KnownFrameworkReference
      Condition="'$(TargetPlatformVersion)' == '11.0'"
      Include="Samsung.Tizen"
      TargetFramework="$(_TargetFramework)"
      TargetingPackName="Samsung.Tizen.Ref.API15"
      Tar
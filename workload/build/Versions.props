<Project>
  <!--
    Workload version:
    * The first two numbers represent the major and minor version of the Tizen OS.
    * The third number is the workload release count.
    * However, the first digit of the third number starts at 101.

    Pre-release version:
    1) CI Versions
       format: -ci.[branch name | gh + #PR].[Commit Distance]+sha[Commit Hash]
       example: -ci.main.100+sha12345
                -ci.gh23.100+sha12345
    2) Official Versions:
       format: -[preview name].[Commit Distance]+sha[Commit Hash]
       example: -preview.3.100+sha12345
  -->
  <PropertyGroup>
    <TizenWorkloadVersion>10.0.121</TizenWorkloadVersion>
  </PropertyGroup>

  <!--
    TizenFX API version per API level (each Samsung.Tizen.Ref.APIxx pack).
  -->
  <PropertyGroup>
    <TizenFXAPI11Version>11.0.0.18033</TizenFXAPI11Version>
    <TizenFXAPI12Version>12.0.0.18510</TizenFXAPI12Version>
    <TizenFXAPI13Version>13.0.0.19198</TizenFXAPI13Version>
    <TizenFXAPI14Version>14.0.0.19300</TizenFXAPI14Version>
    <TizenFXAPI15Version>15.0.0.19371</TizenFXAPI15Version>
  </PropertyGroup>

  <!--
    Dotnet SDK versions for building the workload.
   -->
  <PropertyGroup>
    <MicrosoftDotnetSdkInternalPackageVersion>9.0.300</MicrosoftDotnetSdkInternalPackageVersion>
    <MicrosoftDotNetBuildTasksFeedPackageVersion>9.0.0-beta.25065.2</MicrosoftDotNetBuildTasksFeedPackageVersion>
  </PropertyGroup>
</Project>
